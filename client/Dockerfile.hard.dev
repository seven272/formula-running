# при установки зависимостей прямо на сервере сжирает много памяти. Энергоемкий вариант dev режима
FROM node:22-alpine AS react-build

WORKDIR /app

EXPOSE 3010

COPY package.json /app

COPY package-lock.json /app

RUN npm install

COPY . /app

ENV NODE_OPTIONS="--max-old-space-size=4096"

CMD [ "npm", "run", "start"]



